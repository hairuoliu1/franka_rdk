+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+import logging
+import time
+from threading import Event, Lock, Thread
+from typing import Any
+
+import cv2  # type: ignore
+import numpy as np  # type: ignore
+from numpy.typing import NDArray  # type: ignore
+
+from lerobot.utils.decorators import check_if_already_connected, check_if_not_connected
+from lerobot.utils.errors import DeviceNotConnectedError
+
+from ..camera import Camera
+from ..configs import ColorMode
+from ..utils import get_cv2_rotation
+from .configuration_zed import ZEDCameraConfig
+
+logger = logging.getLogger(__name__)
+
+try:
+    import pyzed.sl as sl  # type: ignore
+except Exception as e:
+    sl = None
+    _PYZED_IMPORT_ERROR = e
+else:
+    _PYZED_IMPORT_ERROR = None
+
+
+def _require_pyzed() -> None:
+    if sl is None:
+        raise ImportError(
+            "pyzed is not available. Install ZED SDK Python bindings before using ZED cameras."
+        ) from _PYZED_IMPORT_ERROR
+
+
+def _sl_resolution(width: int | None, height: int | None):
+    if width is None or height is None:
+        return None
+    presets = {
+        (2208, 1242): sl.RESOLUTION.HD2K,
+        (1920, 1080): sl.RESOLUTION.HD1080,
+        (1280, 720): sl.RESOLUTION.HD720,
+        (672, 376): sl.RESOLUTION.VGA,
+    }
+    return presets.get((width, height))
+
+
+class ZEDCamera(Camera):
+    """ZED camera wrapper with the same interface as other LeRobot cameras."""
+
+    def __init__(self, config: ZEDCameraConfig):
+        super().__init__(config)
+
+        _require_pyzed()
+
+        self.config = config
+        self.serial_number = None if config.serial_number is None else int(config.serial_number)
+        self.camera_model = config.camera_model
+        self.color_mode = config.color_mode
+        self.warmup_s = config.warmup_s
+        self.rotation = get_cv2_rotation(config.rotation)
+
+        self.zed: sl.Camera | None = None
+        self.runtime_params: sl.RuntimeParameters | None = None
+        self.image_mat: sl.Mat | None = None
+
+        self.thread: Thread | None = None
+        self.stop_event: Event | None = None
+        self.frame_lock: Lock = Lock()
+        self.latest_frame: NDArray[Any] | None = None
+        self.latest_timestamp: float | None = None
+        self.new_frame_event: Event = Event()
+
+        if self.height and self.width:
+            self.capture_width, self.capture_height = self.width, self.height
+            if self.rotation in [cv2.ROTATE_90_CLOCKWISE, cv2.ROTATE_90_COUNTERCLOCKWISE]:
+                self.capture_width, self.capture_height = self.height, self.width
+
+    def __str__(self) -> str:
+        identifier = self.serial_number if self.serial_number is not None else "default"
+        return f"{self.__class__.__name__}({identifier})"
+
+    @property
+    def is_connected(self) -> bool:
+        return self.zed is not None
+
+    @staticmethod
+    def find_cameras() -> list[dict[str, Any]]:
+        _require_pyzed()
+
+        found: list[dict[str, Any]] = []
+        for device in sl.Camera.get_device_list():
+            found.append(
+                {
+                    "type": "ZED",
+                    "id": str(device.serial_number),
+                    "name": str(device.camera_model),
+                    "serial_number": str(device.serial_number),
+                    "camera_model": str(device.camera_model),
+                    "input_type": str(device.input_type),
+                }
+            )
+        return found
+
+    @check_if_already_connected
+    def connect(self, warmup: bool = True) -> None:
+        _require_pyzed()
+
+        init_params = sl.InitParameters()
+        resolution = _sl_resolution(self.width, self.height)
+        if resolution is not None:
+            init_params.camera_resolution = resolution
+        if self.fps is not None:
+            init_params.camera_fps = int(self.fps)
+        if self.serial_number is not None:
+            init_params.set_from_serial_number(self.serial_number)
+
+        camera = sl.Camera()
+        status = camera.open(init_params)
+        if status != sl.ERROR_CODE.SUCCESS:
+            raise ConnectionError(f"Failed to open {self}: {status}")
+
+        info = camera.get_camera_information()
+        resolution_obj = info.camera_configuration.resolution
+        actual_width = int(resolution_obj.width)
+        actual_height = int(resolution_obj.height)
+        actual_fps = int(info.camera_configuration.fps)
+
+        if self.rotation in [cv2.ROTATE_90_CLOCKWISE, cv2.ROTATE_90_COUNTERCLOCKWISE]:
+            self.width, self.height = actual_height, actual_width
+            self.capture_width, self.capture_height = actual_width, actual_height
+        else:
+            self.width, self.height = actual_width, actual_height
+            self.capture_width, self.capture_height = actual_width, actual_height
+        self.fps = actual_fps
+
+        self.zed = camera
+        self.runtime_params = sl.RuntimeParameters()
+        self.image_mat = sl.Mat(actual_width, actual_height, sl.MAT_TYPE.U8_C4)
+        self._start_read_thread()
+
+        if warmup and self.warmup_s > 0:
+            start_time = time.time()
+            while time.time() - start_time < self.warmup_s:
+                self.async_read(timeout_ms=max(int(self.warmup_s * 1000), 1000))
+                time.sleep(0.1)
+            with self.frame_lock:
+                if self.latest_frame is None:
+                    raise ConnectionError(f"{self} failed to capture frames during warmup.")
+
+        logger.info("%s connected.", self)
+
+    def _postprocess_image(self, image: NDArray[Any]) -> NDArray[Any]:
+        if image.ndim != 3 or image.shape[2] < 3:
+            raise RuntimeError(f"Unexpected ZED image shape: {image.shape}")
+
+        # ZED returns U8_C4 images in BGRA order. Normalize to either RGB or BGR
+        # so downstream dataset/video code sees the same channel contract as the
+        # other camera backends.
+        if image.shape[2] == 4:
+            if self.color_mode == ColorMode.BGR:
+                image = cv2.cvtColor(image, cv2.COLOR_BGRA2BGR)
+            else:
+                image = cv2.cvtColor(image, cv2.COLOR_BGRA2RGB)
+        else:
+            if self.color_mode == ColorMode.BGR:
+                image = cv2.cvtColor(image, cv2.COLOR_RGB2BGR)
+            else:
+                image = image[:, :, :3]
+
+        if self.rotation is not None:
+            image = cv2.rotate(image, self.rotation)
+
+        return image
+
+    def _read_from_hardware(self) -> NDArray[Any]:
+        if self.zed is None or self.runtime_params is None or self.image_mat is None:
+            raise DeviceNotConnectedError(f"{self} is not connected.")
+
+        status = self.zed.grab(self.runtime_params)
+        if status != sl.ERROR_CODE.SUCCESS:
+            raise RuntimeError(f"{self} grab failed: {status}")
+
+        self.zed.retrieve_image(self.image_mat, sl.VIEW.LEFT)
+        frame = self.image_mat.get_data()
+        if frame is None:
+            raise RuntimeError(f"{self} returned no image data.")
+        return self._postprocess_image(np.array(frame, copy=True))
+
+    def _read_loop(self) -> None:
+        assert self.stop_event is not None
+        while not self.stop_event.is_set():
+            try:
+                frame = self._read_from_hardware()
+                with self.frame_lock:
+                    self.latest_frame = frame
+                    self.latest_timestamp = time.perf_counter()
+                    self.new_frame_event.set()
+            except Exception as e:
+                logger.debug("%s background read failed: %s", self, e)
+                time.sleep(0.05)
+
+    def _start_read_thread(self) -> None:
+        self.stop_event = Event()
+        self.new_frame_event.clear()
+        self.thread = Thread(target=self._read_loop, name=f"zed_camera_{self.serial_number}", daemon=True)
+        self.thread.start()
+
+    @check_if_not_connected
+    def read(self) -> NDArray[Any]:
+        start_time = time.perf_counter()
+        self.new_frame_event.clear()
+        frame = self.async_read(timeout_ms=10000)
+        logger.debug("%s read took %.1fms", self, (time.perf_counter() - start_time) * 1e3)
+        return frame
+
+    @check_if_not_connected
+    def async_read(self, timeout_ms: float = 200) -> NDArray[Any]:
+        if self.thread is None or not self.thread.is_alive():
+            raise RuntimeError(f"{self} read thread is not running.")
+
+        if not self.new_frame_event.wait(timeout=timeout_ms / 1000):
+            raise TimeoutError(f"Timed out waiting for a new frame from {self}.")
+
+        with self.frame_lock:
+            frame = self.latest_frame
+            self.new_frame_event.clear()
+
+        if frame is None:
+            raise RuntimeError(f"{self} has no frame available.")
+        return frame
+
+    @check_if_not_connected
+    def read_latest(self, max_age_ms: int = 500) -> NDArray[Any]:
+        with self.frame_lock:
+            frame = self.latest_frame
+            timestamp = self.latest_timestamp
+
+        if frame is None or timestamp is None:
+            raise RuntimeError(f"{self} has not captured any frame yet.")
+        age_ms = (time.perf_counter() - timestamp) * 1000
+        if age_ms > max_age_ms:
+            raise TimeoutError(f"Latest frame from {self} is stale ({age_ms:.1f}ms > {max_age_ms}ms).")
+        return frame
+
+    def disconnect(self) -> None:
+        if not self.is_connected:
+            return
+
+        if self.stop_event is not None:
+            self.stop_event.set()
+        if self.thread is not None:
+            self.thread.join(timeout=1.0)
+        self.thread = None
+        self.stop_event = None
+        self.new_frame_event.clear()
+
+        if self.zed is not None:
+            self.zed.close()
+        self.zed = None
+        self.runtime_params = None
+        self.image_mat = None
+        self.latest_frame = None
+        self.latest_timestamp = None
