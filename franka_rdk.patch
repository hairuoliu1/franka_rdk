+def main(argv: Sequence[str] | None = None) -> int:
+    register_third_party_plugins()
+    arg_parser = _build_parser()
+    args, extra = arg_parser.parse_known_args(argv)
+
+    if args.command not in {"action-listener", "obs-listener"} and extra:
+        arg_parser.error(f"unrecognized arguments: {' '.join(extra)}")
+
+    if args.command == "action-listener":
+        return _run_action_listener(extra, args.count, args.interval)
+    if args.command == "obs-listener":
+        return _run_obs_listener(extra, args.count, args.interval)
+    if args.command == "fake-action":
+        return _run_fake_action_publisher(args.rate_hz, args.namespace, args.duration_s)
+    if args.command == "fake-state":
+        return _run_fake_state_publisher(args.rate_hz, args.namespace, args.duration_s)
+    if args.command == "camera-test":
+        return _run_camera_test(args.frames, args.interval)
+    if args.command == "gripper-test":
+        return _run_gripper_cycle(args.cycles, args.settle_time_s)
+    if args.command == "read-ee-pose":
+        return _run_read_ee_pose(args.rate_hz, args.base_frame, args.tip_frame, args.samples)
+    if args.command == "franka-ik":
+        return _run_franka_ik(args.x, args.y, args.z, args.qx, args.qy, args.qz, args.qw)
+
+    raise AssertionError(f"Unhandled command: {args.command}")
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
