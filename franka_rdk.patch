+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+_ROOT_ENV_VARS = ("LEROBOT_FRANKA_RDK_ROOT", "FRANKA_RDK_ROOT")
+
+
+def _candidate_roots() -> list[Path]:
+    candidates: list[Path] = []
+    for env_name in _ROOT_ENV_VARS:
+        raw_value = os.environ.get(env_name)
+        if raw_value:
+            candidates.append(Path(raw_value).expanduser().resolve())
+    candidates.extend([Path(__file__).resolve(), Path.cwd().resolve()])
+    return candidates
+
+
+def find_repo_root() -> Path:
+    for candidate in _candidate_roots():
+        for parent in [candidate, *candidate.parents]:
+            if (parent / "configs" / "camera.yaml").is_file():
+                return parent
+
+    env_hint = " or ".join(f"${name}" for name in _ROOT_ENV_VARS)
+    raise FileNotFoundError(
+        "Could not locate Franka RDK repository root. "
+        f"Set {env_hint} or keep configs/camera.yaml alongside the repository root."
+    )
+
+
+def camera_yaml_path() -> Path:
+    path = find_repo_root() / "configs" / "camera.yaml"
+    if not path.is_file():
+        raise FileNotFoundError(f"Missing camera config file: {path}")
+    return path
