+import numpy as np
+import pytest
+
+from lerobot.cameras.configs import ColorMode
+
+pytest.importorskip("pyzed")
+
+from lerobot.cameras.zed import ZEDCamera, ZEDCameraConfig
+
+
+def test_postprocess_image_converts_bgra_to_rgb():
+    camera = ZEDCamera(ZEDCameraConfig(serial_number="123", color_mode=ColorMode.RGB))
+    bgra = np.array([[[255, 255, 0, 17]]], dtype=np.uint8)
+
+    rgb = camera._postprocess_image(bgra)
+
+    assert rgb.shape == (1, 1, 3)
+    np.testing.assert_array_equal(rgb[0, 0], np.array([0, 255, 255], dtype=np.uint8))
+
+
+def test_postprocess_image_converts_bgra_to_bgr():
+    camera = ZEDCamera(ZEDCameraConfig(serial_number="123", color_mode=ColorMode.BGR))
+    bgra = np.array([[[255, 255, 0, 17]]], dtype=np.uint8)
+
+    bgr = camera._postprocess_image(bgra)
+
+    assert bgr.shape == (1, 1, 3)
+    np.testing.assert_array_equal(bgr[0, 0], np.array([255, 255, 0], dtype=np.uint8))
