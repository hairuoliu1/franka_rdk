+# limitations under the License.
+
+"""Manual Franka data-path tests.
+
+This module replaces the old ``lerobot.scripts.franka_rdk.debug`` script.
+It lives under ``tests/`` so Franka-specific checks stay with the repo-local
+integration surface instead of occupying a product CLI namespace.
+"""
+
+from __future__ import annotations
+
+import argparse
+import os
+import shlex
+import time
+from collections.abc import Sequence
+
+import draccus
+import pytest
+
+from lerobot.utils.import_utils import register_third_party_plugins
+
+
+RUN_FRANKA_TESTS = os.environ.get("LEROBOT_RUN_FRANKA_TESTS") == "1"
+ALLOW_FRANKA_MOTION = os.environ.get("LEROBOT_FRANKA_ALLOW_MOTION") == "1"
+
+pytestmark = pytest.mark.skipif(
+    not RUN_FRANKA_TESTS,
+    reason="Set LEROBOT_RUN_FRANKA_TESTS=1 to run Franka hardware and ROS tests.",
+)
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(prog="test_franka_data")
+    subparsers = parser.add_subparsers(dest="command", required=True)
+
+    action_parser = subparsers.add_parser("action-listener", help="Listen to GELLO actions.")
+    action_parser.add_argument("--count", type=int, default=20)
+    action_parser.add_argument("--interval", type=float, default=0.1)
+
+    obs_parser = subparsers.add_parser("obs-listener", help="Listen to robot observations.")
+    obs_parser.add_argument("--count", type=int, default=20)
+    obs_parser.add_argument("--interval", type=float, default=0.1)
+
+    fake_action_parser = subparsers.add_parser("fake-action", help="Publish fake GELLO actions.")
+    fake_action_parser.add_argument("--rate-hz", type=float, default=30.0)
+    fake_action_parser.add_argument("--duration-s", type=float, default=2.0)
+    fake_action_parser.add_argument(
+        "--namespace", "--topic_namespace", "--topic-namespace", dest="namespace", default=""
+    )
+
+    fake_state_parser = subparsers.add_parser("fake-state", help="Publish fake robot observations.")
+    fake_state_parser.add_argument("--rate-hz", type=float, default=30.0)
+    fake_state_parser.add_argument("--duration-s", type=float, default=2.0)
+    fake_state_parser.add_argument(
+        "--namespace", "--topic_namespace", "--topic-namespace", dest="namespace", default=""
+    )
+
+    camera_parser = subparsers.add_parser("camera-test", help="Connect to configured cameras and read frames.")
+    camera_parser.add_argument("--frames", type=int, default=10)
+    camera_parser.add_argument("--interval", type=float, default=0.1)
+
+    gripper_parser = subparsers.add_parser("gripper-test", help="Run a short gripper open-close cycle.")
+    gripper_parser.add_argument("--cycles", type=int, default=2)
+    gripper_parser.add_argument("--settle-time-s", type=float, default=1.0)
+
+    pose_parser = subparsers.add_parser("read-ee-pose", help="Read the current end-effector pose from TF.")
+    pose_parser.add_argument("--samples", type=int, default=10)
+    pose_parser.add_argument("--rate-hz", type=float, default=5.0)
+    pose_parser.add_argument("--base-frame", type=str, default="fr3_link0")
+    pose_parser.add_argument("--tip-frame", type=str, default="fr3_link8")
+
+    ik_parser = subparsers.add_parser("franka-ik", help="Solve a single Franka IK query.")
+    ik_parser.add_argument("--x", type=float, default=0.3069)
+    ik_parser.add_argument("--y", type=float, default=0.0)
+    ik_parser.add_argument("--z", type=float, default=0.5903)
+    ik_parser.add_argument("--qx", type=float, default=0.924)
+    ik_parser.add_argument("--qy", type=float, default=-0.383)
+    ik_parser.add_argument("--qz", type=float, default=0.0)
+    ik_parser.add_argument("--qw", type=float, default=0.0)
+
+    return parser
+
+
+def _env_int(name: str, default: int) -> int:
+    return int(os.environ.get(name, str(default)))
+
+
+def _env_float(name: str, default: float) -> float:
+    return float(os.environ.get(name, str(default)))
+
+
+def _env_args(name: str) -> list[str]:
+    raw = os.environ.get(name, "")
+    return shlex.split(raw) if raw else []
+
+
+def _normalize_namespace_args(extra: Sequence[str]) -> list[str]:
+    normalized: list[str] = []
+    i = 0
+    aliases = {"--namespace", "--topic-namespace"}
+    while i < len(extra):
+        arg = extra[i]
+        if arg in aliases and i + 1 < len(extra) and not extra[i + 1].startswith("-"):
+            normalized.append(f"--topic_namespace={extra[i + 1]}")
+            i += 2
+            continue
+        if arg.startswith("--namespace="):
+            normalized.append(f"--topic_namespace={arg.split('=', 1)[1]}")
+        elif arg.startswith("--topic-namespace="):
+            normalized.append(f"--topic_namespace={arg.split('=', 1)[1]}")
+        else:
+            normalized.append(arg)
+        i += 1
+    return normalized
+
+
+def _summarize_frame(frame) -> str:
+    shape = getattr(frame, "shape", None)
+    dtype = getattr(frame, "dtype", None)
+    if shape is not None and dtype is not None:
+        return f"shape={tuple(shape)}, dtype={dtype}"
+    return f"type={type(frame)}"
+
+
+def _spin_node_for_duration(rclpy, node, duration_s: float) -> None:
+    deadline = time.monotonic() + max(duration_s, 0.0)
+    while time.monotonic() < deadline:
+        timeout = min(0.1, max(deadline - time.monotonic(), 0.0))
+        rclpy.spin_once(node, timeout_sec=timeout)
+
+
+def _run_action_listener(config_args: Sequence[str], count: int, interval: float) -> int:
+    from lerobot.teleoperators import make_teleoperator_from_config
+    from lerobot.teleoperators.gello_leader.config_gello_ros_leader import GelloRosLeaderConfig
+
+    register_third_party_plugins()
+    cfg = draccus.parse(config_class=GelloRosLeaderConfig, args=_normalize_namespace_args(config_args))
+    teleop = make_teleoperator_from_config(cfg)
+    teleop.connect()
+    try:
+        for i in range(count):
+            action = teleop.get_action()
+            arm = [action.get(f"joint_positions_{j}", 0.0) for j in range(7)]
+            gripper = action.get("joint_positions_7", 0.0)
+            print(f"[{i:06d}] arm={[round(v, 4) for v in arm]} gripper={gripper:.4f}")
+            time.sleep(max(interval, 0.0))
+    except KeyboardInterrupt:
+        return 130
+    finally:
+        teleop.disconnect()
+    return 0
+
+
+def _run_obs_listener(config_args: Sequence[str], count: int, interval: float) -> int:
+    from lerobot.robots import make_robot_from_config
+    from lerobot.robots.franka_fr3_robotiq_gripper.config_franka_fr3_robotiq_gripper import (
+        FrankaFr3RobotiqGripperConfig,
+    )
+
+    register_third_party_plugins()
+    cfg = draccus.parse(config_class=FrankaFr3RobotiqGripperConfig, args=_normalize_namespace_args(config_args))
+    robot = make_robot_from_config(cfg)
+    robot.connect()
+    try:
+        for i in range(count):
+            obs = robot.get_observation()
+            arm = [obs.get(f"joint_positions_{j}", 0.0) for j in range(7)]
+            gripper = obs.get("joint_positions_7", 0.0)
+            print(f"[{i:06d}] arm={[round(v, 4) for v in arm]} gripper={gripper:.4f}")
+            time.sleep(max(interval, 0.0))
+    except KeyboardInterrupt:
+        return 130
+    finally:
+        robot.disconnect()
+    return 0
+
+
+def _run_camera_test(frames: int, interval: float) -> int:
+    from lerobot.cameras.utils import make_cameras_from_configs
+    from lerobot.robots.franka_fr3_robotiq_gripper.config_franka_fr3_robotiq_gripper import (
+        FrankaFr3RobotiqGripperConfig,
+    )
+
+    register_third_party_plugins()
+    config = FrankaFr3RobotiqGripperConfig()
+    cameras = make_cameras_from_configs(config.cameras)
+
+    print("=== Franka Camera Test ===")
+    print(f"Configured cameras: {list(cameras.keys())}")
+
+    try:
+        for name, cam in cameras.items():
+            cam.connect()
+            print(f"[OK] Connected: {name}")
+
+        for frame_idx in range(frames):
+            for name, cam in cameras.items():
+                frame = cam.read()
+                print(f"frame {frame_idx + 1:03d} | {name}: {_summarize_frame(frame)}")
+            time.sleep(max(interval, 0.0))
+
+        return 0
+    except Exception as exc:
+        print(f"[FAIL] Camera test failed: {exc}")
+        return 1
+    finally:
+        for name, cam in cameras.items():
+            try:
+                cam.disconnect()
+                print(f"[OK] Disconnected: {name}")
+            except Exception as exc:
+                print(f"[WARN] Failed to disconnect {name}: {exc}")
+
+
+def _run_gripper_cycle(cycles: int, settle_time_s: float) -> int:
+    from lerobot.robots import make_robot_from_config
+    from lerobot.robots.franka_fr3_robotiq_gripper.config_franka_fr3_robotiq_gripper import (
+        FrankaFr3RobotiqGripperConfig,
+    )
+
+    register_third_party_plugins()
+    config = FrankaFr3RobotiqGripperConfig(cameras={})
+    robot = make_robot_from_config(config)
+    robot.connect()
+
+    try:
+        for cycle_idx in range(cycles):
+            for label, target_value in (("OPEN", 0.0), ("CLOSE", 0.085)):
+                obs = robot.get_observation()
+                action = {f"joint_positions_{i}": obs.get(f"joint_positions_{i}", 0.0) for i in range(7)}
+                action["joint_positions_7"] = target_value
+                print(f"cycle={cycle_idx + 1:02d} command={label} target={target_value:.3f}")
+                robot.send_action(action)
+                time.sleep(max(settle_time_s, 0.0))
+                new_obs = robot.get_observation()
+                print(f"feedback joint_positions_7={new_obs['joint_positions_7']:.4f}")
+    finally:
+        robot.disconnect()
+
+    return 0
+
+
+def _run_read_ee_pose(rate_hz: float, base_frame: str, tip_frame: str, samples: int) -> int:
+    import rclpy
+    from rclpy.node import Node
+    from tf2_ros import TransformException
+    from tf2_ros.buffer import Buffer
+    from tf2_ros.transform_listener import TransformListener
+
+    rclpy.init()
+    node = Node("franka_pose_reader")
+    tf_buffer = Buffer()
+    tf_listener = TransformListener(tf_buffer, node)
+    successes = 0
+
+    try:
+        for _ in range(samples):
+            _spin_node_for_duration(rclpy, node, 1.0 / max(rate_hz, 1e-6))
+            try:
+                transform = tf_buffer.lookup_transform(base_frame, tip_frame, rclpy.time.Time())
+            except TransformException as exc:
+                print(f"[WARN] TF not ready: {exc}")
+                continue
+
+            x = transform.transform.translation.x
+            y = transform.transform.translation.y
+            z = transform.transform.translation.z
+            qx = transform.transform.rotation.x
+            qy = transform.transform.rotation.y
+            qz = transform.transform.rotation.z
+            qw = transform.transform.rotation.w
+            print(f"XYZ: [{x:.4f}, {y:.4f}, {z:.4f}]")
+            print(f"Quat: [{qx:.4f}, {qy:.4f}, {qz:.4f}, {qw:.4f}]")
+            successes += 1
+    finally:
+        del tf_listener
+        node.destroy_node()
+        rclpy.shutdown()
+
+    return 0 if successes > 0 else 1
+
+
+def _run_franka_ik(x: float, y: float, z: float, qx: float, qy: float, qz: float, qw: float) -> int:
+    import rclpy
+    from geometry_msgs.msg import PoseStamped
+    from moveit_msgs.srv import GetPositionIK
+    from rclpy.node import Node
+
+    class FrankaIKSolver(Node):
+        def __init__(self) -> None:
+            super().__init__("franka_ik_solver")
+            self.ik_client = self.create_client(GetPositionIK, "/compute_ik")
+            while not self.ik_client.wait_for_service(timeout_sec=1.0):
+                self.get_logger().info("waiting for /compute_ik...")
+
+        def solve_ik(self, target_xyz: list[float], target_quat: list[float]):
+            req = GetPositionIK.Request()
+            req.ik_request.group_name = "fr3_arm"
+            req.ik_request.ik_link_name = "fr3_link8"
+
+            pose = PoseStamped()
+            pose.header.frame_id = "fr3_link0"
+            pose.header.stamp = self.get_clock().now().to_msg()
+            pose.pose.position.x = target_xyz[0]
+            pose.pose.position.y = target_xyz[1]
+            pose.pose.position.z = target_xyz[2]
+            pose.pose.orientation.x = target_quat[0]
+            pose.pose.orientation.y = target_quat[1]
+            pose.pose.orientation.z = target_quat[2]
+            pose.pose.orientation.w = target_quat[3]
+            req.ik_request.pose_stamped = pose
+            req.ik_request.timeout.sec = 0
+            req.ik_request.timeout.nanosec = 50_000_000
+
+            future = self.ik_client.call_async(req)
+            rclpy.spin_until_future_complete(self, future)
+            response = future.result()
+            if response is None:
+                self.get_logger().error("IK service returned no response.")
+                return None
+            if response.error_code.val == response.error_code.SUCCESS:
+                for name, pos in zip(response.solution.joint_state.name, response.solution.joint_state.position):
+                    print(f"{name}: {pos:.4f} rad")
+                return response.solution.joint_state.position
+            self.get_logger().error("IK failed: %s", response.error_code.val)
+            return None
+
+    rclpy.init()
+    node = FrankaIKSolver()
+    try:
+        result = node.solve_ik([x, y, z], [qx, qy, qz, qw])
+    finally:
+        node.destroy_node()
+        rclpy.shutdown()
+
+    return 0 if result is not None else 1
+
+
+def _run_fake_action_publisher(rate_hz: float, namespace: str, duration_s: float) -> int:
+    import math
+
+    import rclpy
+    from rclpy.executors import ExternalShutdownException
+    from rclpy.node import Node
+    from sensor_msgs.msg import JointState
+    from std_msgs.msg import Float32
+
+    class FakeGelloPublisher(Node):
+        def __init__(self) -> None:
+            node_name = "fake_gello_publisher" if not namespace else f"{namespace.strip('/')}_fake_gello_publisher"
+            super().__init__(node_name)
+            self.publish_rate_hz = rate_hz
+            self.joint_names = [f"fr3_joint{i}" for i in range(1, 8)]
+            prefix = f"/{namespace.strip('/')}" if namespace else ""
+            self.arm_joint_publisher = self.create_publisher(JointState, f"{prefix}/gello/joint_states", 10)
+            self.gripper_joint_publisher = self.create_publisher(
+                Float32, f"{prefix}/gripper/gripper_client/target_gripper_width_percent", 10
+            )
+            self.gripper_raw_publisher = self.create_publisher(Float32, f"{prefix}/gello/gripper_position", 10)
+            self.timer = self.create_timer(1 / self.publish_rate_hz, self.publish_joint_jog)
+            self.start_time = time.time()
+            self.last_logged_tick = -1
+
+        def infer_joint_and_gripper_positions(self):
+            elapsed = time.time() - self.start_time
+            joints = [0.1 * math.sin(elapsed + i) for i in range(7)]
+            gripper = 0.085 * ((math.sin(elapsed * 1.5) + 1.0) / 2.0)
+            return joints, gripper
+
+        def publish_joint_jog(self) -> None:
+            gello_arm_joints, gripper_position = self.infer_joint_and_gripper_positions()
+            elapsed = time.time() - self.start_time
+
+            arm_joint_states = JointState()
+            arm_joint_states.header.stamp = self.get_clock().now().to_msg()
+            arm_joint_states.name = self.joint_names
+            arm_joint_states.header.frame_id = "fr3_link0"
+            arm_joint_states.position = [float(v) for v in gello_arm_joints]
+
+            gripper_position = float(min(0.085, max(0.0, gripper_position)))
+            gripper_joint_states = Float32()
+            gripper_joint_states.data = 1.0 - (gripper_position / 0.085)
+            gripper_raw_states = Float32()
+            gripper_raw_states.data = gripper_position
+
+            self.arm_joint_publisher.publish(arm_joint_states)
+            self.gripper_joint_publisher.publish(gripper_joint_states)
+            self.gripper_raw_publisher.publish(gripper_raw_states)
+
+            current_tick = int(elapsed * self.publish_rate_hz)
+            if current_tick % 30 == 0 and current_tick != self.last_logged_tick:
+                self.last_logged_tick = current_tick
+                self.get_logger().info(
+                    "Fake output -> Arm: %s, Gripper target raw: %.3f, open percent: %.3f",
+                    [round(j, 3) for j in gello_arm_joints],
+                    gripper_raw_states.data,
+                    gripper_joint_states.data,
+                )
+
+    rclpy.init()
+    try:
+        fake_publisher = FakeGelloPublisher()
+    except Exception as exc:
+        print(f"Failed to initialize fake publisher: {exc}")
+        rclpy.try_shutdown()
+        return 1
+
+    try:
+        _spin_node_for_duration(rclpy, fake_publisher, duration_s)
+    except (KeyboardInterrupt, ExternalShutdownException):
+        pass
+    finally:
+        fake_publisher.destroy_node()
+        rclpy.try_shutdown()
+    return 0
+
+
+def _run_fake_state_publisher(rate_hz: float, namespace: str, duration_s: float) -> int:
+    import math
+
+    import rclpy
+    from rclpy.executors import ExternalShutdownException
+    from rclpy.node import Node
+    from sensor_msgs.msg import JointState
+
+    class FakeRobotStatePublisher(Node):
+        def __init__(self) -> None:
+            node_name = (
+                "fake_robot_state_publisher"
+                if not namespace
+                else f"{namespace.strip('/')}_fake_robot_state_publisher"
+            )
+            super().__init__(node_name)
+            self.publish_rate_hz = rate_hz
+            self.arm_joint_names = [f"fr3_joint{i}" for i in range(1, 8)]
+            prefix = f"/{namespace.strip('/')}" if namespace else ""
+            self.arm_state_publisher = self.create_publisher(JointState, f"{prefix}/franka/joint_states", 10)
+            self.gripper_state_publisher = self.create_publisher(JointState, f"{prefix}/gripper/joint_states", 10)
+            self.timer = self.create_timer(1 / self.publish_rate_hz, self.publish_state)
+            self.start_time = time.time()
+            self.last_logged_tick = -1
+
+        def publish_state(self) -> None:
+            elapsed = time.time() - self.start_time
+            arm_joints = [0.2 * math.cos(elapsed + i) for i in range(7)]
+            gripper_pos = 0.085 * ((math.sin(elapsed * 2.0) + 1.0) / 2.0)
+
+            arm_state_msg = JointState()
+            arm_state_msg.header.stamp = self.get_clock().now().to_msg()
+            arm_state_msg.name = self.arm_joint_names
+            arm_state_msg.position = [float(v) for v in arm_joints]
+
+            gripper_state_msg = JointState()
+            gripper_state_msg.header.stamp = self.get_clock().now().to_msg()
+            gripper_state_msg.name = ["robotiq_85_left_knuckle_joint"]
+            gripper_state_msg.position = [float(gripper_pos)]
+
+            self.arm_state_publisher.publish(arm_state_msg)
+            self.gripper_state_publisher.publish(gripper_state_msg)
+
+            current_tick = int(elapsed * self.publish_rate_hz)
+            if current_tick % 30 == 0 and current_tick != self.last_logged_tick:
+                self.last_logged_tick = current_tick
+                self.get_logger().info(
+                    "Fake State -> Arm: %s, Gripper: %.3f",
+                    [round(j, 3) for j in arm_joints],
+                    gripper_pos,
+                )
+
+    rclpy.init()
+    try:
+        fake_state_publisher = FakeRobotStatePublisher()
+    except Exception as exc:
+        print(f"Failed to initialize fake state publisher: {exc}")
+        rclpy.try_shutdown()
+        return 1
+
+    try:
+        _spin_node_for_duration(rclpy, fake_state_publisher, duration_s)
+    except (KeyboardInterrupt, ExternalShutdownException):
+        pass
+    finally:
+        fake_state_publisher.destroy_node()
+        rclpy.try_shutdown()
+    return 0
+
