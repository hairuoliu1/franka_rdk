+from __future__ import annotations
+
+from copy import deepcopy
+from dataclasses import dataclass, field
+from functools import lru_cache
+
+import draccus
+
+from lerobot.cameras import CameraConfig
+from lerobot.cameras.opencv.configuration_opencv import OpenCVCameraConfig  # noqa: F401
+from lerobot.cameras.zed.configuration_zed import ZEDCameraConfig  # noqa: F401
+
+from .paths import camera_yaml_path
+
+__all__ = [
+    "FrankaCameraLayoutConfig",
+    "default_left_arm_cameras",
+    "default_right_arm_cameras",
+    "load_camera_layout",
+]
+
+
+@dataclass
+class FrankaCameraLayoutConfig:
+    left_arm: dict[str, CameraConfig] = field(default_factory=dict)
+    right_arm: dict[str, CameraConfig] = field(default_factory=dict)
+
+
+@lru_cache(maxsize=1)
+def _load_camera_layout() -> FrankaCameraLayoutConfig:
+    with camera_yaml_path().open("r", encoding="utf-8") as f:
+        return draccus.load(FrankaCameraLayoutConfig, f)
+
+
+def load_camera_layout() -> FrankaCameraLayoutConfig:
+    return deepcopy(_load_camera_layout())
+
+
+def default_left_arm_cameras() -> dict[str, CameraConfig]:
+    return deepcopy(_load_camera_layout().left_arm)
+
+
+def default_right_arm_cameras() -> dict[str, CameraConfig]:
+    return deepcopy(_load_camera_layout().right_arm)
