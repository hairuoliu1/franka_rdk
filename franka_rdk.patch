+import time
+
+from lerobot.configs import parser
+from lerobot.robots import make_robot_from_config
+from lerobot.robots.franka_fr3_robotiq_gripper.config_franka_fr3_robotiq_gripper import (
+    FrankaFr3RobotiqGripperConfig,
+)
+from lerobot.utils.import_utils import register_third_party_plugins
+
+
+@parser.wrap()
+def run(cfg: FrankaFr3RobotiqGripperConfig):
+    if not cfg.cameras:
+        cfg.cameras = {}
+    robot = make_robot_from_config(cfg)
+    robot.connect()
+    try:
+        obs = robot.get_observation()
+        for step in [0.0, 0.085, 0.0, 0.085]:
+            action = {f"joint_positions_{i}": obs.get(f"joint_positions_{i}", 0.0) for i in range(7)}
+            action["joint_positions_7"] = step
+            print(f"Sending gripper target: {step}")
+            robot.send_action(action)
+            for _ in range(20):
+                time.sleep(0.1)
+                current = robot.get_observation().get("joint_positions_7", 0.0)
+                print(f"Current gripper feedback: {current:.4f}", end="\r")
+            print()
+    finally:
+        robot.disconnect()
+
+
+def main():
+    register_third_party_plugins()
+    run()
+
+
+if __name__ == "__main__":
+    main()
