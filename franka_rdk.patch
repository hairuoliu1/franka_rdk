@@ -0,0 +1,35 @@
+import importlib
+import logging
+
+logger = logging.getLogger(__name__)
+
+PLUGIN_MODULES = (
+    "lerobot.robots.franka_fr3_robotiq_gripper",
+    "lerobot.robots.bi_franka_fr3_robotiq_gripper",
+    "lerobot.teleoperators.gello_leader",
+    "lerobot.teleoperators.bi_gello_leader",
+)
+
+OPTIONAL_PLUGIN_MODULES = (
+    "lerobot.policies.openpi_client",
+    "lerobot.cameras.zed",
+)
+
+_REGISTERED = False
+
+
+def register() -> None:
+    global _REGISTERED
+    if _REGISTERED:
+        return
+
+    for module_name in PLUGIN_MODULES:
+        importlib.import_module(module_name)
+
+    for module_name in OPTIONAL_PLUGIN_MODULES:
+        try:
+            importlib.import_module(module_name)
+        except Exception as exc:
+            logger.warning("Could not import optional Franka RDK plugin %s: %s", module_name, exc)
+
+    _REGISTERED = True
