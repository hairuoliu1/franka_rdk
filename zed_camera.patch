+
+from dataclasses import dataclass
+
+from ..configs import CameraConfig, ColorMode, Cv2Rotation
+
+
+@CameraConfig.register_subclass("zed")
+@CameraConfig.register_subclass("zed2")
+@dataclass
+class ZEDCameraConfig(CameraConfig):
+    """Configuration class for Stereolabs ZED cameras.
+
+    Attributes:
+        serial_number: Optional camera serial number. If omitted, the ZED SDK selects the first camera.
+        color_mode: Color mode for image output (RGB or BGR). Defaults to RGB.
+        rotation: Image rotation setting (0, 90, 180, or 270 degrees). Defaults to no rotation.
+        warmup_s: Time reading frames before returning from connect, in seconds.
+    """
+
+    serial_number: str | None = None
+    color_mode: ColorMode = ColorMode.RGB
+    rotation: Cv2Rotation = Cv2Rotation.NO_ROTATION
+    warmup_s: int = 1
+
+    def __post_init__(self) -> None:
+        self.color_mode = ColorMode(self.color_mode)
+        self.rotation = Cv2Rotation(self.rotation)
+
+        values = (self.fps, self.width, self.height)
+        if any(v is not None for v in values) and any(v is None for v in values):
+            raise ValueError(
+                "For `fps`, `width` and `height`, either all of them need to be set, or none of them."
+            )
